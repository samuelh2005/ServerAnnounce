{
	"schemaVersion": 1,
	"id": "server-announce",
	"version": "${version}",
	"name": "Server Announce",
	"description": "Allows the Minecraft server to discover servers from a central server list.",
	"authors": [
		"samuelh2005"
	],
	"contact": {
		"sources": "https://github.com/samuelh2005/ServerAnnounce",
		"issues": "https://github.com/samuelh2005/ServerAnnounce/issues"
	},
	"license": "LGPL-3.0",
	"icon": "assets/server-announce/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"me.samuelh2005.server_announce.ServerAnnounce"
		]
	},
	"mixins": [
		"server-announce.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": ">=${fabric_api_version}",
		"yet_another_config_lib_v3": ">=${yacl_version}"
	}
}